# Copy to .env and adjust. (.env is gitignored.)

# Where the built game archives are served from (see `npm run serve:static`).
VITE_STATIC_URL=http://localhost:3001

# Game variant to boot: original | carcer (selects the archive set + player spawn). Default: original.
VITE_GAME_TYPE=original

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX). Used only to count visitors.
# Leave unset (e.g. in dev) to skip analytics entirely.
VITE_GA_ID=

# Asset loader: fetch | local. Default: fetch.
#   fetch — download the built manifest + chunks from VITE_STATIC_URL.
#   local — read a user-picked raw GTA San Andreas install folder (Chromium only; File System Access API).
VITE_ASSET_LOADER=fetch

# Main character from peds.ide
VITE_MAIN_CHARACTER=BMYPOL1

# Vehicles from vehicles.ide
VITE_VEHICLES=['admiral','comet']
