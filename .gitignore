.env
.env.production
.env.*.local

# temp directory
.temp
.tmp

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json


# Built game archives + rendered artifacts under static/ are ignored; only the small committed
# viewer fixtures (static/viewer/) are tracked, so the asset-light viewers + e2e run anywhere.
/static/*
!/static/viewer/
game-src
issues
map-optimizer
blog-src

# Real GTA SA test fixtures (Rockstar assets — not redistributed): regenerated locally from a stock
# copy at game-src/non-modified via `npm run test:fixtures`. Committed fixtures (mods + curated /
# version-pinned test models) live in tests/custom/, which stays tracked.
/tests/original/
