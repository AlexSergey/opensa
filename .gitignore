# Everything under static/ is generated from a local GTA copy and gitignored: the built game archives
# (npm run build:game) and the viewer fixtures (npm run viewer:assets — extracted from game-src/non-modified).
# No Rockstar assets are committed.
/static/
game-src
issues
ideas
blog-src

# map-optimizer / lod-generator are tracked sub-projects; ignore only their generated output + local scratch.
map-optimizer/out/
map-optimizer/*.jpg
lod-generator/out/

# Real GTA SA test fixtures (Rockstar assets — not redistributed): regenerated locally from a stock
# copy at game-src/non-modified via `npm run test:fixtures`. Committed fixtures (mods + curated /
# version-pinned test models) live in tests/custom/, which stays tracked.
/tests/original/
