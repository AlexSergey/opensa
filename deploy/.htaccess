# Apache config for deploying the built app (dist/) on shared hosting.
# Place this next to index.html in the web root. Requires mod_rewrite + mod_headers
# (and mod_mime / mod_deflate, usually enabled on shared hosts).
#
# Deploy alongside: the static asset archives under  static/<GAME_TYPE>-<version>/
# (manifest.json + the priority/models/textures chunk zips). The runtime fetches
# them from VITE_STATIC_URL, which is baked at build time.
#
# NOTE: HTTPS is required — the asset loader uses the Cache Storage API, which only
# works in a secure context. Enable TLS (e.g. Let's Encrypt) and force https below.

# ---------------------------------------------------------------------------
# Force HTTPS (Cache Storage / secure-context APIs need it).
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # http -> https (skip if your host terminates TLS and sets X-Forwarded-Proto).
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # SPA fallback: serve index.html for any path that isn't a real file or directory.
  # Real assets (js/css/zip/json/images) and the static/ archives are served directly.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# ---------------------------------------------------------------------------
# Caching.
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Content-hashed assets (Vite js/css, fonts) and the content-hashed chunk zips
  # (priority-<hash>.zip / models-<hash>.zip / textures-<hash>.zip) never change for a
  # given name — cache them forever.
  <FilesMatch "\.(js|mjs|css|woff2?|ttf|zip|wasm)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # manifest.json points at the current chunk hashes, and index.html bootstraps the
  # app — a stale copy breaks loading. Always revalidate these.
  <FilesMatch "(manifest\.json|index\.html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------------
# MIME types (fallbacks in case the host doesn't know them).
# ---------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType application/json .json
  AddType application/wasm .wasm
  AddType application/zip  .zip
</IfModule>

# ---------------------------------------------------------------------------
# Compression. mod_deflate compresses text only; the chunk zips / wasm are already
# compressed, so list explicit text types and leave the rest untouched.
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Range requests (resumable / parallel chunk downloads) are served by default — no config needed.
