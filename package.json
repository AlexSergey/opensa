{
  "name": "prod-forge-todolist-frontend",
  "version": "1.2.2",
  "description": "An experiment in creating a project from scratch using Claude Code",
  "homepage": "https://github.com/AlexSergey/todolist-ai#readme",
  "bugs": {
    "url": "https://github.com/AlexSergey/todolist-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexSergey/todolist-ai.git"
  },
  "license": "MIT",
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com>",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "format": "npm run format:prettier && npm run format:code",
    "format:code": "eslint . --fix",
    "format:prettier": "prettier --write \"src/**/*.{ts,json}\"",
    "gen:ipl-manifest": "node scripts/gen-ipl-manifest.mjs",
    "knip": "knip",
    "lint": "npm run lint:ts && npm run lint:code",
    "lint:code": "eslint .",
    "lint:commit": "commitlint --config .commitlintrc.cjs --edit",
    "lint:ts": "tsc --noEmit",
    "viewer:collision": "tsx scripts/extract-viewer-collision.ts",
    "pack:anim": "node scripts/pack-anim-img.mjs",
    "pack:img": "node scripts/pack-img.mjs",
    "preview": "vite preview",
    "serve:static": "serve static -l 3001 --cors",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.19.3",
    "bitecs": "0.4.0",
    "postprocessing": "6.39.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@eslint-react/eslint-plugin": "5.7.8",
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "@inquirer/checkbox": "5.1.5",
    "@inquirer/prompts": "8.4.3",
    "@playwright/test": "1.60.0",
    "@release-it/bumper": "7.0.5",
    "@release-it/conventional-changelog": "11.0.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.177.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "10.3.0",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-import-lite": "0.6.0",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-storybook": "10.4.0",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "knip": "6.13.1",
    "lint-staged": "17.0.4",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "react-doctor": "0.1.6",
    "release-it": "20.0.1",
    "serve": "14.2.6",
    "stylelint": "16.13.2",
    "stylelint-config-standard": "36.0.1",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vite-plugin-istanbul": "8.0.0",
    "vitest": "4.1.6"
  }
}
